<% layout("/layouts/boilerplate") %>
<div class="row"> 
    <div class="col-8 offset-2">
        <br>
    <h3> Create a new listings</h3>
    <form method="POST" action="/listings" class="needs-validation" novalidate enctype="multipart/form-data">

        <div class="md-3">  
            <label for="title" class="form-label">Title</label>
            <input name="listing[title]" placeholder="Enter Title" type="text" class="form-control" required/>
            <div class="valid-feedback">Title is good</div>
        </div>
        
           
      
        <div class="md-3">   
            <label for="description" class="form-label">Description</label>
            <textarea name="listing[description]" placeholder="Enter Description" type="text" class="form-control" required></textarea>
            <div class="invalid-feedback">Valid Description</div>
        </div>
         
         


        <!-- <div class="md-3">
            <label for="image" class="form-label">Image</label>
            <input name="listing[image][url]" placeholder="Enter Image URL/link" class="form-control"/>
        </div> -->
         



        <div class="md-3">
            <label for="image" class="form-label">Uplod Listing Image</label>
            <input name="listing[image]"  class="form-control" type="file" required/>
        </div>


       

        <div class="row">
             <div class="md-3 col-md-4">
            <label for="Price" class="form-label">Price</label>
            <input name="listing[price]" placeholder="Enter Price" type="number" class="form-control" required/>
            <div class="invalid-feedback">Valid Price</div>
        </div>
         
        
 

        <div class="md-3 col-md-8">
            <label for="Location" class="form-label">Location</label>  
            <input name="listing[location]" placeholder="Enter Location" type="text" class="form-control" required/>
            <div class="invalid-feedback">Valid Location</div>
        </div>
        </div>
       
         
          
        


        <div class="md-3">
            <label for="Country" class="form-label">Country</label>
            <input name="listing[country]" placeholder="Enter Country" type="text" class="form-control" required/>
            <div class="invalid-feedback">Valid Country</div>
        </div>
         
        <br>
          <button class="btn btn-dark add-btn">Add</button>         
    </form>
    </div>
</div> 