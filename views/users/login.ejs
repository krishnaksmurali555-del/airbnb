<% layout("/layouts/boilerplate") %>
<div class="row"> 
    <h1 class="col-6 offset-3">Login for Wonderlust</h1>
    <div class="col-6 offset-3">
        <form action="/login" method="POST" class="needs-validation novalidate">


         <div class="md-3">  
            <label for="username" class="form-label">Username</label>
            <input name="username" placeholder="Enter Username" type="text" class="form-control" required id="username"/>
        </div>
    







          <div class="md-3">  
            <label for="password" class="form-label">password</label>
            <input name="password" placeholder="Enter password" type="password" class="form-control" required id="password"/>
        </div>
        <br>
        

        <button class="btn btn-success">Login</button>
        


        

        </form>

        </div>

        </div>